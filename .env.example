# NVIDIA Nemotron Super 3 via NIM
# Get your key at: build.nvidia.com
NVIDIA_API_KEY=...
ANTHROPIC_API_KEY=...

# OpenShell gateway selection
# The active gateway is read from ~/.config/openshell/active_gateway
# Set it with: openshell gateway select <name>
# Override here if needed:
# OPENSHELL_GATEWAY=my-cluster

# Optional: connect to a pre-existing sandbox by name instead of creating a fresh one.
# Create one with: openshell sandbox create --name my-sandbox --keep
OPENSHELL_SANDBOX_NAME=deepagent-sandbox

# LangSmith (optional - for tracing)
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT="openshell-deep-agent"
LANGSMITH_TRACING="true"

AGENT_MODEL="anthropic:claude-sonnet-4-6"